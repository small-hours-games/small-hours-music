# Suno API base URL (your self-hosted gcui-art/suno-api instance)
SUNO_API_URL=http://localhost:3001

# Suno API key (optional — depends on your suno-api setup)
SUNO_API_KEY=your_api_key_here

# Domain for public URLs (optional — defaults to local IP)
DOMAIN=music.yourdomain.com

# Port to listen on (default: 3000)
PORT=3000
